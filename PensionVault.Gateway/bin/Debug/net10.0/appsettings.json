{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "PensionVault$SuperSecretKey#2024@JwtTokenSigningKey!MustBe32Chars",
    "Issuer": "PensionVault",
    "Audience": "PensionVaultUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "employers-route": {
        "ClusterId": "employermember-cluster",
        "Match": {
          "Path": "/api/employers/{**catch-all}"
        }
      },
      "schemes-route": {
        "ClusterId": "employermember-cluster",
        "Match": {
          "Path": "/api/schemes/{**catch-all}"
        }
      },
      "members-route": {
        "ClusterId": "employermember-cluster",
        "Match": {
          "Path": "/api/members/{**catch-all}"
        }
      },
      "remittances-route": {
        "ClusterId": "fundops-cluster",
        "Match": {
          "Path": "/api/remittances/{**catch-all}"
        }
      },
      "ledger-route": {
        "ClusterId": "fundops-cluster",
        "Match": {
          "Path": "/api/ledger/{**catch-all}"
        }
      },
      "annuity-route": {
        "ClusterId": "fundops-cluster",
        "Match": {
          "Path": "/api/annuity/{**catch-all}"
        }
      },
      "claims-route": {
        "ClusterId": "claimsinvestment-cluster",
        "Match": {
          "Path": "/api/claims/{**catch-all}"
        }
      },
      "portfolios-route": {
        "ClusterId": "claimsinvestment-cluster",
        "Match": {
          "Path": "/api/portfolios/{**catch-all}"
        }
      },
      "corpus-route": {
        "ClusterId": "claimsinvestment-cluster",
        "Match": {
          "Path": "/api/corpus/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notificationreporting-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "reports-route": {
        "ClusterId": "notificationreporting-cluster",
        "Match": {
          "Path": "/api/reports/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "employermember-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "fundops-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "claimsinvestment-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "notificationreporting-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5005"
          }
        }
      }
    }
  }
}
